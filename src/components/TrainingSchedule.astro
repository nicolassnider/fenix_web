---
import { getTrainingSchedule } from '../data/training-schedule';
import type { TrainingSchedule } from '../types';

const schedules = await getTrainingSchedule();
---

<div class="w-full">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {schedules.map((schedule: TrainingSchedule) => (
            <div class="card-dark">
                <div class="flex items-start justify-between mb-4">
                    <div>
                        <h3 class="text-2xl font-bold text-white">{schedule.day}</h3>
                        <p class="text-fenix-orange font-semibold text-lg">{schedule.time}</p>
                    </div>
                    <div class="text-3xl">
                        {schedule.day.includes('Lunes') || schedule.day.includes('Miércoles') ? '👶' : 
                         schedule.day.includes('Martes') || schedule.day.includes('Jueves') ? '🧑' : '👨'}
                    </div>
                </div>
                <p class="text-gray-400 text-sm mb-4">
                    Duración: 1 hora
                </p>
                <button class="btn-secondary w-full text-sm">
                    Ver Detalles
                </button>
            </div>
        ))}
    </div>

    <!-- Nota adicional -->
    <div class="mt-12 bg-fenix-darkgray rounded-lg p-6 border-l-4 border-fenix-gold">
        <h3 class="text-xl font-bold mb-2">💡 Horarios Personalizados</h3>
        <p class="text-gray-300">
            ¿No encuentras el horario que buscas? Ofrecemos entrenamiento personalizado para grupos específicos. Contáctanos para más información.
        </p>
    </div>
</div>