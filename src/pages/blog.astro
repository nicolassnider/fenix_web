---
import Layout from '../layouts/Layout.astro';
import { getBlogPostsFromFirebase } from '../lib/blog-posts-firebase';
import { getBlogPosts } from '../data/blog-posts';
import type { BlogPost } from '../types';
import BlogModal from '../components/BlogModal.astro';
import BlogCard from '../components/BlogCard.astro';

const title = "Blog - Academia Fenix";
// Try to fetch from Firebase first, fallback to JSON
let posts = await getBlogPostsFromFirebase();
if (posts.length === 0) {
  console.log('Using fallback to JSON data');
  posts = await getBlogPosts();
}

// Sort posts by date (newest first)
posts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout>
    <div class="container mx-auto px-4 py-12">
        <h1 class="text-4xl font-bold text-white mb-8">Blog</h1>
        <p class="text-gray-300 text-lg mb-8">
            Actividades y noticias de la escuela
        </p>
        
        <div class="max-w-3xl mx-auto space-y-6">
            {posts.map((post: BlogPost) => (
                <BlogCard post={post} />
            ))}
        </div>
    </div>

    <BlogModal />
</Layout>
