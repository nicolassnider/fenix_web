---
import Layout from '../layouts/Layout.astro';

const title = "Contacto - Academia Fenix";
---

<Layout>
    <div class="container mx-auto px-4 py-12">
        <h1 class="text-4xl font-bold text-white mb-8">Contacto</h1>
        <p class="text-gray-300 text-lg mb-8">
            ¿Tienes preguntas? Contáctanos
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="card-dark">
                <h2 class="text-2xl font-bold text-white mb-6">Envíanos un mensaje</h2>
                <form class="space-y-4">
                    <div>
                        <label class="block text-gray-300 mb-2">Nombre</label>
                        <input type="text" class="w-full bg-fenix-darkgray border border-gray-700 rounded-lg px-4 py-3 text-white focus:border-fenix-orange focus:outline-none" />
                    </div>
                    <div>
                        <label class="block text-gray-300 mb-2">Email</label>
                        <input type="email" class="w-full bg-fenix-darkgray border border-gray-700 rounded-lg px-4 py-3 text-white focus:border-fenix-orange focus:outline-none" />
                    </div>
                    <div>
                        <label class="block text-gray-300 mb-2">Mensaje</label>
                        <textarea rows="4" class="w-full bg-fenix-darkgray border border-gray-700 rounded-lg px-4 py-3 text-white focus:border-fenix-orange focus:outline-none"></textarea>
                    </div>
                    <button type="submit" class="btn-primary w-full">Enviar</button>
                </form>
            </div>
            
            <div class="space-y-6">
                <div class="card-dark">
                    <h3 class="text-xl font-bold text-white mb-4">Información de Contacto</h3>
                    <div class="space-y-3">
                        <p class="text-gray-300">
                            <span class="text-fenix-orange">📍</span> Dirección: [Tu dirección]
                        </p>
                        <p class="text-gray-300">
                            <span class="text-fenix-orange">📧</span> Email: contacto@fenix.com
                        </p>
                        <p class="text-gray-300">
                            <span class="text-fenix-orange">📱</span> Teléfono: [Tu teléfono]
                        </p>
                    </div>
                </div>
                
                <div class="card-dark">
                    <h3 class="text-xl font-bold text-white mb-4">Horarios de Clases</h3>
                    <div class="space-y-2">
                        <p class="text-gray-300">
                            <span class="text-fenix-orange">👶</span> Infantiles: Martes y Jueves 18:30
                        </p>
                        <p class="text-gray-300">
                            <span class="text-fenix-orange">🧑</span> Juveniles y Adultos: Martes y Jueves 19:30
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>
